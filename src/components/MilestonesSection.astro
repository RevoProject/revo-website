---
const { milestonesHTML, t } = Astro.props;
---
<section class="milestones">
  <div class="container">
    <h2>{t("milestones")}</h2>

    <div class="timeline" id="milestones-timeline" set:html={milestonesHTML}></div>

    <div class="history">
      <h3>{t("historyTitle")}</h3>
      <div class="history-list">
        <div class="history-item">
          <div class="history-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.2" fill="none"></rect>
              <path d="M8 2v4M16 2v4M3 10h18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
            </svg>
          </div>
          <div class="history-content">
            <h4>{t("history-step1-title")}</h4>
            <p>{t("history-step1-desc")}</p>
          </div>
        </div>

        <div class="history-item">
          <div class="history-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.2" fill="none"></rect>
              <path d="M8 2v4M16 2v4M3 10h18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
            </svg>
          </div>
          <div class="history-content">
            <h4>{t("history-step2-title")}</h4>
            <p>{t("history-step2-desc")}</p>
          </div>
        </div>

        <div class="history-item">
          <div class="history-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="3" y="4" width="18" height="16" rx="2" stroke="currentColor" stroke-width="1.2" fill="none"></rect>
              <path d="M8 2v4M16 2v4M3 10h18" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
            </svg>
          </div>
          <div class="history-content">
            <h4>{t("history-step3-title")}</h4>
            <p>{t("history-step3-desc")}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
