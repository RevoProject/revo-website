---
import { Image } from "astro:assets";
import revoDemo from "../assets/revostream_demo.webp";

const { t } = Astro.props;
---
<section class="cta">
  <div class="container">
    <h1 class="cta-text">{t("cta")}</h1>
    <div class="cta-screenshot">
      <Image src={revoDemo} alt="RevoStream dashboard preview" fetchpriority="high" loading="eager" decoding="sync" />
    </div>
    <div class="btns-cta">
      <a href="https://github.com/revoproject/revo-stream/releases">
        <button class="btn-primary">{t("tryAlpha")}</button>
      </a>
      <a class="btn-ghost" href="https://github.com/revoproject/revo-stream" target="_blank" rel="noopener noreferrer">
        <svg class="icon-github" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.726-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.757-1.333-1.757-1.089-.744.082-.729.082-.729 1.205.084 1.84 1.236 1.84 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.418-1.305.762-1.605-2.665-.305-5.466-1.334-5.466-5.93 0-1.31.468-2.381 1.235-3.221-.123-.303-.535-1.523.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.289-1.552 3.295-1.23 3.295-1.23.653 1.653.242 2.873.119 3.176.77.84 1.233 1.911 1.233 3.221 0 4.61-2.807 5.624-5.479 5.921.43.372.815 1.103.815 2.222 0 1.606-.015 2.899-.015 3.292 0 .319.216.694.825.576C20.565 22.092 24 17.592 24 12.297 24 5.67 18.627.297 12 .297z"/>
        </svg>
        <span>{t("viewOnGitHub")}</span>
      </a>
    </div>
  </div>
</section>
